# 将此文件复制为 .env，填入真实密钥
# cp .env.example .env
#
# .env 已加入 .gitignore，不会被提交到仓库

# ---- API Keys（四选一，或用通用字段）----

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 GLM
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# 阿里通义千问
# TONGYI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 通用覆盖（优先级最高，可覆盖上面任意一个）
# LLM_API_KEY=

# ---- 可选覆盖（不填则使用 config.yaml 的值）----

# 覆盖模型名
# LLM_MODEL=gpt-4o

# 覆盖自定义端点（如代理或兼容接口）
# LLM_BASE_URL=https://your-proxy.example.com/v1

# 覆盖 Provider
# LLM_PROVIDER=openai

# 覆盖日志级别
# LOG_LEVEL=debug
